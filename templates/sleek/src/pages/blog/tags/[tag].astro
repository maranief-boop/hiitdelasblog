---
import { readAll } from "../../../lib/markdoc/read";
import { blog } from "../../../lib/markdoc/frontmatter.schema";
import PageLayout from "../../../layouts/PageLayout.astro";
import PageMeta from "../../../components/PageMeta.astro";
import { SITE_TITLE } from "../../../config";

export async function getStaticPaths() {
  const posts = await readAll({
    directory: "blog",
    frontmatterSchema: blog,
  });

  // Criamos uma lista de tags única de forma bem direta
  const allTags = new Set();
  posts.forEach((post) => {
    if (post.frontmatter.tags) {
      post.frontmatter.tags.forEach((tag) => allTags.add(tag.toLowerCase().trim()));
    }
  });

  return Array.from(allTags).map((tag) => {
    return {
      params: { tag: tag },
      props: { 
        tag: tag,
        posts: posts.filter((post) => 
          post.frontmatter.tags?.some(t => t.toLowerCase().trim() === tag)
        ) 
      },
    };
  });
}

const { tag, posts } = Astro.props;
const title = tag.toUpperCase();

const sortedPosts = posts
  .filter((p) => !p.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<PageLayout>
  <PageMeta title={`${title} | ${SITE_TITLE}`} slot="meta" />
  <section slot="main">
    <h1 class="text-3xl font-bold mb-6">Categoria: {title}</h1>
    <ul>
      {sortedPosts.map((post) => (
        <li class="mb-4 border-b pb-4">
          <a href={`/blog/${post.slug}`} class="text-xl font-bold hover:text-blue-600">
            {post.frontmatter.title}
          </a>
          <p class="text-gray-600 text-sm mt-1">{post.frontmatter.description}</p>
        </li>
      ))}
    </ul>
    {sortedPosts.length === 0 && <p>Nenhum post encontrado.</p>}
  </section>
</PageLayout>
